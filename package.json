{
  "name": "react-usefavicon",
  "description": "useFavicon: a React Hook to dynamically modify the favicon",
  "author": "Jules Blom (https://twitter.com/Mega_Jules)",
  "private": false,
  "homepage": "https://jules.engineer/usefavicon",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JulesBlm/useFavicon.git"
  },
  "sideEffects": false,
  "main": "./dist/react-usefavicon.js",
  "browser": "./dist/react-usefavicon.umd.js",
  "umd:main": "./dist/react-usefavicon.umd.js",
  "module": "./dist/react-usefavicon.module.js",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-usefavicon.modern.mjs",
      "require": "./dist/react-usefavicon.js",
      "default": "./dist/react-usefavicon.modern.mjs"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "keywords": [
    "favicon",
    "react",
    "react-hook",
    "nextjs",
    "next.js",
    "react-router",
    "tanstack-router",
    "remix",
    "ssr",
    "dynamic-favicon",
    "emoji-favicon"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/JulesBlm"
  },
  "scripts": {
    "build": "rimraf dist && npm run test && npm run build:react",
    "build:react": "microbundle --define process.env.NODE_ENV=production --name usefavicon --no-compress --output dist/",
    "build:ci": "microbundle --define process.env.NODE_ENV=production --name usefavicon --output dist/",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintIgnore": [
    "node_modules",
    "dist"
  ],
  "prettier": {
    "trailingComma": "all",
    "semi": true
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.0",
    "microbundle": "^0.15.1",
    "prettier": "^3.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">= 18.0.0",
    "react-dom": ">= 18.0.0"
  },
  "files": [
    "src",
    "dist"
  ]
}
